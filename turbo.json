{
  "$schema": "https://turborepo.org/schema.json",
  "globalDependencies": ["pnpm-workspace.yaml"],
  "globalEnv": ["GH_TOKEN"],
  "globalPassThroughEnv": [
    "ACTIONS_ID_TOKEN_REQUEST_TOKEN",
    "ACTIONS_ID_TOKEN_REQUEST_URL",
    "NPM_TOKEN"
  ],
  "tasks": {
    "//#quality": {
      "dependsOn": ["//#lint:ci", "//#format"]
    },
    "//#quality:fix": {
      "dependsOn": ["//#lint:fix", "//#format:fix"]
    },
    "//#lint": {},
    "//#lint:ci": {},
    "//#lint:fix": {
      "cache": false
    },
    "//#format": {},
    "//#format:fix": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "../../oxlint.config.ts",
        "../../tsdown.config.ts",
        "src/**",
        "*.cjs",
        "*.js",
        "*.mjs",
        "*.ts",
        "package.json"
      ],
      "outputLogs": "new-only",
      "outputs": ["dist/**", ".next/**"]
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false
    },
    "lint:ts": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "src/**/*.tsx", "*.ts", "tsconfig.json", "vercel.json"],
      "outputLogs": "new-only"
    },
    "semantic-release": {
      "cache": false
    },
    "semantic-release:dry": {
      "cache": false
    },
    "test:unit": {
      "dependsOn": ["^build"]
    },
    "test:unit:coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    }
  },
  "ui": "stream"
}
