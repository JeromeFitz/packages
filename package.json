{
  "name": "@jeromefitz/packages",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JeromeFitz/packages.git"
  },
  "author": {
    "name": "Jerome Fitzgerald",
    "email": "j@jeromefitzgerald.com",
    "url": "https://jeromefitzgerald.com"
  },
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0"
    },
    "runtime": {
      "name": "node",
      "version": ">=24.17.0 <25"
    }
  },
  "scripts": {
    "biome:check": "biome check",
    "biome:write": "biome check --write",
    "build": "turbo run build --filter=[HEAD^1]",
    "build:all": "turbo run build",
    "clean": "turbo run clean --filter=[HEAD^1]",
    "clean:all": "turbo run clean",
    "clean:install": "turbo run clean && ./scripts/clean.sh",
    "commit": "ALLOW_EMPTY=--allow-empty git commit --allow-empty",
    "dev": "turbo run dev --no-cache --parallel --continue",
    "format": "pnpm format:biome:write && pnpm format:prettier:write",
    "format:biome:base": "biome format",
    "format:biome:check": "pnpm format:biome:base",
    "format:biome:write": "pnpm format:biome:base --write",
    "format:prettier:base": "prettier \"./**/package.json\" \"**.{html,md,mdx,yml,yaml}\" \"!pnpm-lock.yaml\" --ignore-unknown",
    "format:prettier:check": "pnpm format:prettier:base --check",
    "format:prettier:write": "pnpm format:prettier:base --write",
    "preinstall": "npx only-allow pnpm",
    "lint": "pnpm run lint:biome && pnpm run format:prettier:check && pnpm run lint:packages",
    "lint:biome": "biome lint",
    "lint:packages": "syncpack lint",
    "prepare": "pnpm is-ci || pnpm dlx husky@9.1.7",
    "semantic-release": "turbo run semantic-release --concurrency=1 --cache-dir='.cache-turbo'",
    "semantic-release:dry": "turbo run semantic-release:dry --concurrency=1 --cache-dir='.cache-turbo'",
    "test": "turbo run test",
    "turbo": "TURBO_TELEMETRY_DISABLED=1 turbo"
  },
  "dependencies": {
    "@arethetypeswrong/core": "0.18.2",
    "@biomejs/biome": "2.4.15",
    "@jeromefitz/conventional-gitmoji": "workspace:*",
    "@jeromefitz/prettier-config": "workspace:*",
    "@jeromefitz/release-notes-generator": "workspace:*",
    "@jeromefitz/semantic": "workspace:*",
    "@jeromefitz/oxlint-config": "workspace:*",
    "@jeromefitz/tsconfig": "workspace:*",
    "@types/node": "24.12.0",
    "ccommit": "workspace:*",
    "dotenv": "17.4.2",
    "is-ci": "4.1.0",
    "lint-staged": "17.0.5",
    "lodash-es": "4.18.0",
    "oxfmt": "0.56.0",
    "publint": "0.3.21",
    "semantic-release": "25.0.3",
    "syncpack": "15.3.1",
    "tsdown": "0.22.0",
    "turbo": "2.9.14",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  }
}
