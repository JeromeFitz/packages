{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "automerge": false,
  "baseBranchPatterns": ["main"],
  "branchPrefix": "deps/",
  "commitMessageAction": "(deps)",
  "commitMessageExtra": "",
  "commitMessagePrefix": "⬆️",
  "commitMessageSuffix": "",
  "commitMessageTopic": " {{depName}}@{{#if isPinDigest}}{{{newDigest}}}{{else}}{{#if isMajor}}{{{newVersion}}}{{else}}{{#if isSingleVersion}}{{{newVersion}}}{{else}}{{#if newValue}}{{{newValue}}}{{else}}{{{newDigest}}}{{/if}}{{/if}}{{/if}}{{/if}}",
  "dependencyDashboard": true,
  "extends": [":semanticCommitsDisabled"],
  "ignorePaths": [
    "**/node_modules/**",
    "**/bower_components/**",
    "config/eslint-config/**",
    "config/jest-config/**",
    "config/jest-presets/**",
    "config/lint-staged/**",
    "config/lighthouse-config/**",
    "examples/design-system/**",
    "packages/design-system/**",
    "packages/spotify/**"
  ],
  "includePaths": ["config/**", "packages/**"],
  "labels": ["📦️ Dependencies"],
  "packageRules": [
    {
      "enabled": false,
      "matchCategories": ["node"]
    },
    {
      "enabled": false,
      "matchFileNames": ["pnpm-workspace.yaml"],
      "matchUpdateTypes": ["major"]
    },
    {
      "matchDatasources": ["npm"],
      "minimumReleaseAge": "1 day"
    },
    {
      "commitMessageAction": "(actions)",
      "commitMessagePrefix": "👷",
      "groupName": "github actions :octocat:",
      "groupSlug": "github-actions",
      "matchPackageNames": ["/^actions/"]
    },
    {
      "allowedVersions": "<25",
      "commitMessageAction": "(deps-dev)",
      "commitMessagePrefix": "📦",
      "matchDepTypes": ["devDependencies", "dependencies"],
      "matchPackageNames": ["@types/node"]
    },
    {
      "commitMessageAction": "(deps)",
      "commitMessagePrefix": "⬆️",
      "matchDepTypes": ["dependencies"]
    },
    {
      "commitMessageAction": "(deps-peer)",
      "commitMessagePrefix": "📦",
      "matchDepTypes": ["peerDependencies"]
    },
    {
      "commitMessageAction": "(deps-dev)",
      "commitMessagePrefix": "📦",
      "matchDepTypes": ["devDependencies"]
    },
    {
      "automerge": true,
      "automergeStrategy": "squash",
      "automergeType": "pr",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"]
    },
    {
      "assignees": ["JeromeFitz"],
      "labels": ["📦 Dependencies", "📦 Dependencies 💥 Breaking 💥", "🛑️ Do Not Merge"],
      "matchUpdateTypes": ["major"],
      "reviewers": ["JeromeFitz"]
    },
    {
      "commitMessageAction": "(deps-dev)",
      "commitMessagePrefix": "📦",
      "groupName": "storybook 📙 ",
      "groupSlug": "storybook",
      "matchPackageNames": ["storybook", "/^@storybook//"]
    },
    {
      "assignees": ["JeromeFitz"],
      "commitMessageAction": "(deps)",
      "commitMessagePrefix": "⬆️",
      "groupName": "radix-ui 🌐 ",
      "groupSlug": "radix-ui",
      "matchPackageNames": ["/^@radix-ui//"],
      "reviewers": ["JeromeFitz"]
    },
    {
      "commitMessageAction": "(deps)",
      "commitMessagePrefix": "⬆️",
      "enabled": false,
      "groupName": "react ⚛️ ",
      "groupSlug": "react",
      "matchPackageNames": ["react", "react-dom"]
    }
  ],
  "prBodyColumns": ["Package", "Update", "Type", "Change"],
  "prFooter": "<!-- COMMIT_BODY_TEXT_END -->",
  "prHeader": "<!-- COMMIT_BODY_TEXT_BEGIN -->",
  "prHourlyLimit": 2,
  "rebaseWhen": "conflicted",
  "semanticCommits": "disabled"
}
