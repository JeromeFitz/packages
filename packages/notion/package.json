{
  "name": "@jeromefitz/notion",
  "version": "0.0.0",
  "private": false,
  "description": "Notion: Custom Client for jeromefitzgerald.com",
  "keywords": [
    "next",
    "next.js",
    "notion"
  ],
  "license": "MIT",
  "author": {
    "name": "Jerome Fitzgerald",
    "email": "j@jeromefitzgerald.com",
    "url": "https://jeromefitzgerald.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JeromeFitz/packages.git",
    "directory": "packages/notion"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./constants": "./dist/constants/index.mjs",
    "./queries": "./dist/queries/index.mjs",
    "./queries/get-blocks-by-id-children": "./dist/queries/get-blocks-by-id-children/index.mjs",
    "./queries/get-databases-by-id-query": "./dist/queries/get-databases-by-id-query/index.mjs",
    "./queries/get-deep-fetch-all-children": "./dist/queries/get-deep-fetch-all-children/index.mjs",
    "./queries/get-info-type": "./dist/queries/get-info-type/index.mjs",
    "./queries/get-notion-listing": "./dist/queries/get-notion-listing/index.mjs",
    "./queries/get-notion-listing-by-date": "./dist/queries/get-notion-listing-by-date/index.mjs",
    "./queries/get-notion-slug": "./dist/queries/get-notion-slug/index.mjs",
    "./queries/get-notion-slug-by-route": "./dist/queries/get-notion-slug-by-route/index.mjs",
    "./queries/get-pages-by-id": "./dist/queries/get-pages-by-id/index.mjs",
    "./queries/get-path-variables": "./dist/queries/get-path-variables/index.mjs",
    "./queries/get-query": "./dist/queries/get-query/index.mjs",
    "./schema": "./dist/schema/index.mjs",
    "./utils": "./dist/utils/index.mjs",
    "./utils/add-time": "./dist/utils/add-time/index.mjs",
    "./utils/data-normalized": "./dist/utils/data-normalized/index.mjs",
    "./utils/data-normalized-results": "./dist/utils/data-normalized-results/index.mjs",
    "./utils/get-data-type": "./dist/utils/get-data-type/index.mjs",
    "./utils/get-title": "./dist/utils/get-title/index.mjs",
    "./utils/get-types": "./dist/utils/get-types/index.mjs",
    "./utils/get-types/_unsupported": "./dist/utils/get-types/_unsupported.mjs",
    "./utils/get-types/checkbox": "./dist/utils/get-types/checkbox.mjs",
    "./utils/get-types/date": "./dist/utils/get-types/date.mjs",
    "./utils/get-types/email": "./dist/utils/get-types/email.mjs",
    "./utils/get-types/files": "./dist/utils/get-types/files.mjs",
    "./utils/get-types/multi-select": "./dist/utils/get-types/multi-select.mjs",
    "./utils/get-types/number": "./dist/utils/get-types/number.mjs",
    "./utils/get-types/people": "./dist/utils/get-types/people.mjs",
    "./utils/get-types/phone-number": "./dist/utils/get-types/phone-number.mjs",
    "./utils/get-types/relation": "./dist/utils/get-types/relation.mjs",
    "./utils/get-types/rich-text": "./dist/utils/get-types/rich-text.mjs",
    "./utils/get-types/rollup": "./dist/utils/get-types/rollup.mjs",
    "./utils/get-types/select": "./dist/utils/get-types/select.mjs",
    "./utils/get-types/title": "./dist/utils/get-types/title.mjs",
    "./utils/get-types/url": "./dist/utils/get-types/url.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf .turbo && rm -rf dist",
    "clean:install": "pnpm run clean && rm -rf node_modules",
    "dev": "tsdown --watch",
    "lint:ts": "tsc --noEmit --declaration",
    "semantic-release": "semantic-release",
    "semantic-release:dry": "semantic-release --dry-run"
  },
  "dependencies": {
    "@notionhq/client": "4.0.2",
    "date-fns": "4.4.0",
    "github-slugger": "2.0.0"
  },
  "devDependencies": {
    "@jeromefitz/utils": "workspace:*",
    "@types/lodash-es": "4.17.12",
    "lodash-es": "4.18.0"
  },
  "peerDependencies": {
    "@jeromefitz/utils": "^4.0.0",
    "lodash-es": "^4.18.0"
  },
  "engines": {
    "node": ">=24"
  }
}
