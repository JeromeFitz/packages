{
  "name": "@jeromefitz/utils",
  "version": "0.0.0",
  "private": false,
  "description": "Utilities used by @JeromeFitz that may be helpful",
  "keywords": [
    "utilities",
    "utils"
  ],
  "license": "MIT",
  "author": {
    "name": "Jerome Fitzgerald",
    "email": "j@jeromefitzgerald.com",
    "url": "https://jeromefitzgerald.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JeromeFitz/packages.git",
    "directory": "packages/utils"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./assert-never": "./dist/assert-never/index.mjs",
    "./async-for-each": "./dist/async-for-each/index.mjs",
    "./avoid-rate-limit": "./dist/avoid-rate-limit/index.mjs",
    "./is-object": "./dist/is-object/index.mjs",
    "./is-object-empty": "./dist/is-object-empty/index.mjs",
    "./is-undefined": "./dist/is-undefined/index.mjs",
    "./lpad": "./dist/lpad/index.mjs",
    "./noop": "./dist/noop/index.mjs",
    "./omit": "./dist/omit/index.mjs",
    "./pick": "./dist/pick/index.mjs",
    "./pubsub": "./dist/pubsub/index.mjs",
    "./range-map": "./dist/range-map/index.mjs",
    "./set-char-at": "./dist/set-char-at/index.mjs",
    "./sort-object": "./dist/sort-object/index.mjs",
    "./string-to-uuid": "./dist/string-to-uuid/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf .turbo && rm -rf dist",
    "clean:install": "pnpm run clean && rm -rf node_modules",
    "dev": "tsdown --watch",
    "lint:ts": "tsc --noEmit --declaration",
    "semantic-release": "semantic-release",
    "semantic-release:dry": "semantic-release --dry-run"
  },
  "devDependencies": {
    "@types/lodash-es": "4.17.12",
    "lodash-es": "4.18.0"
  },
  "peerDependencies": {
    "lodash-es": "^4.18.0"
  },
  "engines": {
    "node": ">=24"
  }
}
