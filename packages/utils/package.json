{
  "name": "@jeromefitz/utils",
  "version": "0.0.0",
  "private": false,
  "description": "Utilities used by @JeromeFitz that may be helpful",
  "keywords": [
    "utilities",
    "utils"
  ],
  "license": "MIT",
  "author": {
    "name": "Jerome Fitzgerald",
    "email": "j@jeromefitzgerald.com",
    "url": "https://jeromefitzgerald.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JeromeFitz/packages.git",
    "directory": "packages/utils"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./assertNever": "./dist/assertNever/index.mjs",
    "./asyncForEach": "./dist/asyncForEach/index.mjs",
    "./avoidRateLimit": "./dist/avoidRateLimit/index.mjs",
    "./isObject": "./dist/isObject/index.mjs",
    "./isObjectEmpty": "./dist/isObjectEmpty/index.mjs",
    "./isUndefined": "./dist/isUndefined/index.mjs",
    "./lpad": "./dist/lpad/index.mjs",
    "./noop": "./dist/noop/index.mjs",
    "./omit": "./dist/omit/index.mjs",
    "./pick": "./dist/pick/index.mjs",
    "./pubsub": "./dist/pubsub/index.mjs",
    "./rangeMap": "./dist/rangeMap/index.mjs",
    "./setCharAt": "./dist/setCharAt/index.mjs",
    "./sortObject": "./dist/sortObject/index.mjs",
    "./stringToUUID": "./dist/stringToUUID/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf .turbo && rm -rf dist",
    "clean:install": "pnpm run clean && rm -rf node_modules",
    "copy": "mkdir -p ./dist && ./scripts/copy.sh",
    "dev": "tsdown --watch",
    "lint:ts": "tsc --noEmit --declaration",
    "semantic-release": "semantic-release",
    "semantic-release:dry": "semantic-release --dry-run"
  },
  "devDependencies": {
    "@types/lodash-es": "4.17.12",
    "lodash-es": "4.18.0"
  },
  "peerDependencies": {
    "lodash-es": "^4.18.0"
  },
  "engines": {
    "node": ">=24"
  }
}
