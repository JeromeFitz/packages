{
  "name": "@jeromefitz/release-notes-generator",
  "version": "0.0.0",
  "private": false,
  "description": "Custom Release Note Generator for Semantic Release.",
  "license": "MIT",
  "author": {
    "name": "Jerome Fitzgerald",
    "email": "j@jeromefitzgerald.com",
    "url": "https://jeromefitzgerald.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JeromeFitz/packages.git",
    "directory": "packages/release-notes-generator"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf .turbo && rm -rf dist",
    "clean:install": "pnpm run clean && rm -rf node_modules",
    "dev": "tsdown --watch",
    "lint:ts": "tsc --noEmit --declaration",
    "semantic-release": "semantic-release",
    "semantic-release:dry": "semantic-release --dry-run",
    "test:unit": "NODE_NO_WARNINGS=1 vitest run",
    "test:unit:coverage": "NODE_NO_WARNINGS=1 vitest run --coverage",
    "test:watch": "NODE_NO_WARNINGS=1 vitest run --watch"
  },
  "dependencies": {
    "@octokit/rest": "22.0.1",
    "conventional-commits-filter": "6.0.0",
    "conventional-commits-parser": "7.0.0",
    "date-fns": "4.4.0",
    "read-package-up": "12.0.0",
    "semver": "7.8.5"
  },
  "devDependencies": {
    "@jeromefitz/conventional-gitmoji": "workspace:*",
    "@types/lodash-es": "4.17.12",
    "lodash-es": "4.18.0"
  },
  "peerDependencies": {
    "lodash-es": "^4.18.0"
  },
  "engines": {
    "node": ">=24"
  },
  "inlinedDependencies": {
    "grapheme-splitter": "1.0.4",
    "title": "4.0.1"
  }
}
