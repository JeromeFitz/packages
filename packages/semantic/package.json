{
  "name": "@jeromefitz/semantic",
  "version": "0.0.0",
  "private": false,
  "description": "Semantic Versioning, Conventional Commits with CI/CD for GitHub Actions.",
  "license": "MIT",
  "author": {
    "name": "Jerome Fitzgerald",
    "email": "j@jeromefitzgerald.com",
    "url": "https://jeromefitzgerald.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JeromeFitz/packages.git",
    "directory": "packages/semantic"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./get-config": "./dist/get-config.mjs",
    "./release.config": "./dist/release.config.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf .turbo && rm -rf dist",
    "clean:install": "pnpm run clean && rm -rf node_modules",
    "dev": "tsdown --watch",
    "lint:ts": "tsc --noEmit --declaration",
    "semantic-release": "semantic-release",
    "semantic-release:dry": "semantic-release --dry-run",
    "test:unit": "NODE_NO_WARNINGS=1 vitest run",
    "test:unit:coverage": "NODE_NO_WARNINGS=1 vitest run --coverage",
    "test:watch": "NODE_NO_WARNINGS=1 vitest run --watch"
  },
  "dependencies": {
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/git": "10.0.1",
    "semantic-release": "25.0.5",
    "semantic-release-commit-filter": "1.0.2",
    "title": "4.0.1"
  },
  "devDependencies": {
    "@jeromefitz/conventional-gitmoji": "workspace:*"
  },
  "peerDependencies": {
    "@jeromefitz/conventional-gitmoji": "^5.0.0"
  },
  "engines": {
    "node": ">=24"
  }
}
