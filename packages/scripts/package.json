{
  "name": "@jeromefitz/scripts",
  "version": "0.0.0",
  "type": "module",
  "description": "Scripts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeromefitz/packages.git"
  },
  "author": {
    "name": "Jerome Fitzgerald",
    "email": "j@jeromefitzgerald.com",
    "url": "https://jeromefitzgerald.com"
  },
  "license": "MIT",
  "private": false,
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./data/labels": "./dist/data/labels.mjs",
    "./data/milestones": "./dist/data/milestones.mjs",
    "./github/label": "./dist/github/label.mjs",
    "./github/milestone": "./dist/github/milestone.mjs",
    "./github/pullRequest": "./dist/github/pullRequest.mjs",
    "./templates/PULL_REQUEST__RELEASE": "./dist/templates/PULL_REQUEST__RELEASE.mjs",
    "./utils/getChars": "./dist/utils/getChars.mjs",
    "./utils/getPackageJson": "./dist/utils/getPackageJson.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf .turbo && rm -rf dist",
    "clean:install": "pnpm run clean && rm -rf node_modules",
    "copy": "mkdir -p ./dist && ./scripts/copy.sh",
    "dev": "tsdown --watch",
    "lint": "pnpm run lint:typescript",
    "lint:typescript": "tsc --noEmit --declaration",
    "semantic-release": "semantic-release",
    "semantic-release:dry": "semantic-release --dry-run"
  },
  "dependencies": {
    "@octokit/rest": "22.0.1",
    "colorize-template": "1.0.0",
    "is-ci": "4.1.0",
    "picocolors": "1.1.1"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "sideEffects": false,
  "inlinedDependencies": {
    "dotenv": "17.3.1"
  }
}
