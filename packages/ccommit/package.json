{
  "name": "ccommit",
  "version": "0.0.0",
  "private": false,
  "description": "😜 ➕ 👔 🟰  ccommit \n  Conventional Commit Generator that interprets commit types from gitmoji and conventional",
  "keywords": [
    "commit",
    "conventional changelog",
    "conventional commits",
    "enquirer",
    "format",
    "gitflow",
    "githubflow",
    "gitmoji",
    "semver"
  ],
  "homepage": "https://github.com/JeromeFitz/packages/tree/main/packages/ccommit#readme",
  "license": "MIT",
  "author": {
    "name": "Jerome Fitzgerald",
    "email": "j@jeromefitzgerald.com",
    "url": "https://jeromefitzgerald.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JeromeFitz/packages.git",
    "directory": "packages/ccommit"
  },
  "bin": {
    "ccommit": "./dist/index.mjs"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf .turbo && rm -rf dist",
    "clean:install": "pnpm run clean && rm -rf node_modules",
    "copy": "mkdir -p ./dist && ./scripts/copy.sh",
    "dev": "tsdown --watch",
    "dry:run": "pnpm run build && node ./dist/index.js -c -n",
    "lint:ts": "tsc --noEmit --declaration",
    "semantic-release": "semantic-release",
    "semantic-release:dry": "semantic-release --dry-run"
  },
  "dependencies": {
    "ansi-colors": "4.1.3",
    "enquirer": "2.4.1",
    "execa": "9.6.1",
    "fuse.js": "7.4.2",
    "meow": "14.1.0"
  },
  "devDependencies": {
    "@types/node": "24.12.0",
    "is-in-ci": "2.0.0"
  },
  "engines": {
    "node": ">=24"
  }
}
