{
  "name": "@jeromefitz/conventional-gitmoji",
  "version": "0.0.0",
  "private": false,
  "description": "Helper package for dual gitmoji / conventional commits",
  "license": "MIT",
  "author": {
    "name": "Jerome Fitzgerald",
    "email": "j@jeromefitzgerald.com",
    "url": "https://jeromefitzgerald.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JeromeFitz/packages.git",
    "directory": "packages/conventional-gitmoji"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./changelog": "./dist/changelog/index.mjs",
    "./changelog/config": "./dist/changelog/config.mjs",
    "./changelog/utils/conventionalChangelog": "./dist/changelog/utils/conventionalChangelog.mjs",
    "./changelog/utils/conventionalRecommendedBump": "./dist/changelog/utils/conventionalRecommendedBump.mjs",
    "./changelog/utils/gitRawCommit": "./dist/changelog/utils/gitRawCommit.mjs",
    "./changelog/utils/parserOpts": "./dist/changelog/utils/parserOpts.mjs",
    "./changelog/utils/transformer": "./dist/changelog/utils/transformer.mjs",
    "./changelog/utils/writerOpts": "./dist/changelog/utils/writerOpts.mjs",
    "./config/rewrites": "./dist/config/rewrites.mjs",
    "./config/types": "./dist/config/types.mjs",
    "./types": "./dist/types/index.mjs",
    "./types/commit": "./dist/types/commit.mjs",
    "./types/commit.types": "./dist/types/commit.types.mjs",
    "./types/releaseRule": "./dist/types/releaseRule.mjs",
    "./types/releaseRule.types": "./dist/types/releaseRule.types.mjs",
    "./utils/getGitmojiConventional": "./dist/utils/getGitmojiConventional.mjs",
    "./utils/getReleaseRules": "./dist/utils/getReleaseRules.mjs",
    "./utils/getTypeSpecs": "./dist/utils/getTypeSpecs.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf .turbo && rm -rf dist",
    "clean:install": "pnpm run clean && rm -rf node_modules",
    "copy": "mkdir -p ./dist && ./scripts/copy.sh",
    "dev": "tsdown --watch",
    "lint:ts": "tsc --noEmit --declaration",
    "semantic-release": "semantic-release",
    "semantic-release:dry": "semantic-release --dry-run",
    "test": "vitest run"
  },
  "dependencies": {
    "fast-json-stable-stringify": "2.1.0",
    "grapheme-splitter": "1.0.4",
    "title": "4.0.1"
  },
  "devDependencies": {
    "@types/lodash-es": "4.17.12",
    "gitmojis": "3.15.0",
    "lodash-es": "4.18.0"
  },
  "peerDependencies": {
    "lodash-es": "^4.18.0"
  },
  "engines": {
    "node": ">=24"
  },
  "inlinedDependencies": {
    "gitmojis": "3.15.0"
  }
}
