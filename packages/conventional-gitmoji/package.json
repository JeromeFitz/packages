{
  "name": "@jeromefitz/conventional-gitmoji",
  "version": "0.0.0",
  "private": false,
  "description": "Helper package for dual gitmoji / conventional commits",
  "license": "MIT",
  "author": {
    "name": "Jerome Fitzgerald",
    "email": "j@jeromefitzgerald.com",
    "url": "https://jeromefitzgerald.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JeromeFitz/packages.git",
    "directory": "packages/conventional-gitmoji"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./changelog": {
      "development": "./src/changelog/index.ts",
      "default": "./dist/changelog/index.mjs"
    },
    "./changelog/config": {
      "development": "./src/changelog/config.ts",
      "default": "./dist/changelog/config.mjs"
    },
    "./changelog/utils/conventional-changelog": {
      "development": "./src/changelog/utils/conventional-changelog.ts",
      "default": "./dist/changelog/utils/conventional-changelog.mjs"
    },
    "./changelog/utils/conventional-recommended-bump": {
      "development": "./src/changelog/utils/conventional-recommended-bump.ts",
      "default": "./dist/changelog/utils/conventional-recommended-bump.mjs"
    },
    "./changelog/utils/git-raw-commit": {
      "development": "./src/changelog/utils/git-raw-commit.ts",
      "default": "./dist/changelog/utils/git-raw-commit.mjs"
    },
    "./changelog/utils/parser-opts": {
      "development": "./src/changelog/utils/parser-opts.ts",
      "default": "./dist/changelog/utils/parser-opts.mjs"
    },
    "./changelog/utils/transformer": {
      "development": "./src/changelog/utils/transformer.ts",
      "default": "./dist/changelog/utils/transformer.mjs"
    },
    "./changelog/utils/writer-opts": {
      "development": "./src/changelog/utils/writer-opts.ts",
      "default": "./dist/changelog/utils/writer-opts.mjs"
    },
    "./config/rewrites": {
      "development": "./src/config/rewrites.ts",
      "default": "./dist/config/rewrites.mjs"
    },
    "./config/types": {
      "development": "./src/config/types.ts",
      "default": "./dist/config/types.mjs"
    },
    "./types": {
      "development": "./src/types/index.ts",
      "default": "./dist/types/index.mjs"
    },
    "./types/commit": {
      "development": "./src/types/commit.ts",
      "default": "./dist/types/commit.mjs"
    },
    "./types/commit.types": {
      "development": "./src/types/commit.types.ts",
      "default": "./dist/types/commit.types.mjs"
    },
    "./types/release-rule": {
      "development": "./src/types/release-rule.ts",
      "default": "./dist/types/release-rule.mjs"
    },
    "./types/release-rule.types": {
      "development": "./src/types/release-rule.types.ts",
      "default": "./dist/types/release-rule.types.mjs"
    },
    "./utils/get-gitmoji-conventional": {
      "development": "./src/utils/get-gitmoji-conventional.ts",
      "default": "./dist/utils/get-gitmoji-conventional.mjs"
    },
    "./utils/get-release-rules": {
      "development": "./src/utils/get-release-rules.ts",
      "default": "./dist/utils/get-release-rules.mjs"
    },
    "./utils/get-type-specs": {
      "development": "./src/utils/get-type-specs.ts",
      "default": "./dist/utils/get-type-specs.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./changelog": "./dist/changelog/index.mjs",
      "./changelog/config": "./dist/changelog/config.mjs",
      "./changelog/utils/conventional-changelog": "./dist/changelog/utils/conventional-changelog.mjs",
      "./changelog/utils/conventional-recommended-bump": "./dist/changelog/utils/conventional-recommended-bump.mjs",
      "./changelog/utils/git-raw-commit": "./dist/changelog/utils/git-raw-commit.mjs",
      "./changelog/utils/parser-opts": "./dist/changelog/utils/parser-opts.mjs",
      "./changelog/utils/transformer": "./dist/changelog/utils/transformer.mjs",
      "./changelog/utils/writer-opts": "./dist/changelog/utils/writer-opts.mjs",
      "./config/rewrites": "./dist/config/rewrites.mjs",
      "./config/types": "./dist/config/types.mjs",
      "./types": "./dist/types/index.mjs",
      "./types/commit": "./dist/types/commit.mjs",
      "./types/commit.types": "./dist/types/commit.types.mjs",
      "./types/release-rule": "./dist/types/release-rule.mjs",
      "./types/release-rule.types": "./dist/types/release-rule.types.mjs",
      "./utils/get-gitmoji-conventional": "./dist/utils/get-gitmoji-conventional.mjs",
      "./utils/get-release-rules": "./dist/utils/get-release-rules.mjs",
      "./utils/get-type-specs": "./dist/utils/get-type-specs.mjs",
      "./package.json": "./package.json"
    },
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf .turbo && rm -rf dist",
    "clean:install": "pnpm run clean && rm -rf node_modules",
    "dev": "tsdown --watch",
    "lint:ts": "tsc --noEmit --declaration",
    "semantic-release": "semantic-release",
    "semantic-release:dry": "semantic-release --dry-run",
    "test:unit": "NODE_NO_WARNINGS=1 vitest run",
    "test:unit:coverage": "NODE_NO_WARNINGS=1 vitest run --coverage",
    "test:watch": "NODE_NO_WARNINGS=1 vitest run --watch"
  },
  "dependencies": {
    "fast-json-stable-stringify": "2.1.0",
    "grapheme-splitter": "1.0.4",
    "title": "4.0.1"
  },
  "devDependencies": {
    "@types/lodash-es": "4.17.12",
    "gitmojis": "3.15.0",
    "lodash-es": "4.18.0"
  },
  "peerDependencies": {
    "lodash-es": "^4.18.0"
  },
  "engines": {
    "node": ">=24"
  },
  "inlinedDependencies": {
    "gitmojis": "3.15.0"
  }
}
